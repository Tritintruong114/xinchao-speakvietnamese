# pnpm config
# Use isolated linker to prevent duplication issues
node-linker=isolated
# Shamefully hoist for legacy compatibility if needed, but isolated is safer.
shamefully-hoist=true

# Stabilize fetch for Node 24+ pnpm interaction
fetch-retries=3
fetch-retry-maxtimeout=10000
fetch-retry-mintimeout=5000
network-concurrency=8
