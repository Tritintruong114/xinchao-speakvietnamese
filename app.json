{
  "expo": {
    "name": "xinchao",
    "slug": "xinchao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/logo_rectangle.png",
    "scheme": "xinchao",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icons/logo_rectangle.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuhocproduct.xinchao",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icons/logo_rectangle.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
