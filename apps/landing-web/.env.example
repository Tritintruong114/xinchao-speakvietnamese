# Supabase (same project URL as mobile; use service role only on the server — never NEXT_PUBLIC_*)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com) — transactional email after waitlist/contact save
RESEND_API_KEY=
# Verified sender, e.g. XinChao <waitlist@yourdomain.com> (verify domain in Resend)
EMAIL_FROM=

# Where you receive admin copies (defaults to CONTACT_EMAIL / site default)
# OWNER_EMAIL=

# Optional fallbacks if Supabase env is not set
# WAITLIST_WEBHOOK_URL=
# CONTACT_WEBHOOK_URL=
# CONTACT_EMAIL=
# Canonical site URL (SEO: Open Graph, sitemap, robots — set in production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
