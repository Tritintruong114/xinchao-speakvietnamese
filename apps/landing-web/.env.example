# Supabase (same project URL as mobile; use service role only on the server — never NEXT_PUBLIC_*)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Same URL as public — used by next/image remotePatterns for Storage URLs (covers, assets)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Resend (https://resend.com) — transactional email after waitlist/contact save
RESEND_API_KEY=
# Verified sender, e.g. XinChao <waitlist@yourdomain.com> (verify domain in Resend)
EMAIL_FROM=

# Where you receive admin copies (defaults to CONTACT_EMAIL / site default)
# OWNER_EMAIL=

# Optional fallbacks if Supabase env is not set
# WAITLIST_WEBHOOK_URL=
# CONTACT_WEBHOOK_URL=
# CONTACT_EMAIL=
# Canonical site URL (SEO: Open Graph, sitemap, robots — set in production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ElevenLabs (dashboard “Generate audio” — optional server fallbacks when not in Supabase dashboard_settings)
# ELEVENLABS_API_KEY=   # usually stored in dashboard_settings; env can override in some deploys
# Voice id from https://elevenlabs.io/app/voice-library
# ELEVENLABS_VOICE_ID=
# TTS model: e.g. eleven_v3, eleven_multilingual_v2 (default if unset)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Optional encoding (SDK parity): mp3_44100_128
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Dashboard login (cookie session). Set a strong secret in production.
#DASHBOARD_SESSION_SECRET=dev-xinchao-dashboard-session-secret
# Optional overrides (default: admin@gmail.com / xinchaovietnam in dev)
# DASHBOARD_ADMIN_EMAIL=admin@gmail.com
# DASHBOARD_ADMIN_PASSWORD=xinchaovietnam
