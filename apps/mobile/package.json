{
  "name": "@xinchao/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "dev": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "typecheck": "tsc --noEmit",
    "dev:reset:ios": "npx uri-scheme open \"exp://127.0.0.1:8081/--/dev-reset\" --ios",
    "dev:reset:android": "npx uri-scheme open \"exp://127.0.0.1:8081/--/dev-reset\" --android",
    "dev:reset:devbuild:ios": "npx uri-scheme open \"xinchao://dev-reset\" --ios",
    "dev:reset:devbuild:android": "npx uri-scheme open \"xinchao://dev-reset\" --android"
  },
